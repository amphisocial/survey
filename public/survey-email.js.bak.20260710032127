(async()=>{await Athena.requireAuth();const id=new URLSearchParams(location.search).get('id');Athena.appShell('survey-email.html',`<div class="page-head"><div><h1>Email survey</h1><p class="muted">Send the public survey link to a group. The email FROM uses your email where SMTP allows it.</p></div><a class="btn soft" href="/survey-detail.html?id=${id}">Back</a></div><div class="grid two"><section class="panel"><h2>Send email</h2><div class="form-grid"><label>Recipients<textarea id="emails" rows="6" placeholder="One email per line or comma-separated"></textarea></label><label>Subject<input id="subject" value="Please respond to this survey"></label><label>Body<textarea id="body" rows="7">Hi,\n\nPlease take a minute to respond to this short survey.\n\nThank you.</textarea></label><button class="btn primary" id="send">Send</button><div class="error" id="err"></div></div></section><section class="panel"><h2>Email groups</h2><p class="muted">Create reusable groups, then paste/import members. MVP supports direct sends plus group storage APIs.</p><label>New group<input id="groupName"></label><button class="btn soft" id="createGroup">Create group</button><div id="groups" class="list" style="margin-top:14px"></div></section></div>`);async function loadGroups(){const d=await Athena.api('/api/email-groups');Athena.$('#groups').innerHTML=d.groups.map(g=>`<div class="card"><strong>${Athena.escapeHtml(g.name)}</strong><p class="muted">Group ID: ${g.id}</p></div>`).join('')||'<p class="muted">No groups yet.</p>'}Athena.$('#createGroup').onclick=async()=>{try{await Athena.api('/api/email-groups',{method:'POST',body:JSON.stringify({name:Athena.$('#groupName').value})});Athena.$('#groupName').value='';loadGroups();}catch(e){Athena.toast(e.message)}};Athena.$('#send').onclick=async()=>{try{Athena.$('#err').textContent='';const r=await Athena.api(`/api/surveys/${id}/send-email`,{method:'POST',body:JSON.stringify({emails:Athena.$('#emails').value,subject:Athena.$('#subject').value,body:Athena.$('#body').value})});Athena.toast(`Sent to ${r.recipients} recipients.`);}catch(e){Athena.$('#err').textContent=e.message}};loadGroups();})();
